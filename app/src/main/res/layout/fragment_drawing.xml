<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 工具列 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/colorSurface"
        android:elevation="2dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical">

            <!-- 顏色選擇 -->
            <View
                android:id="@+id/btnColorBlack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="6dp" />

            <View
                android:id="@+id/btnColorRed"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="6dp" />

            <View
                android:id="@+id/btnColorBlue"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="6dp" />

            <View
                android:id="@+id/btnColorGreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="12dp" />

            <!-- 筆觸大小 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPenSmall"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="12dp"
                android:text="細" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPenLarge"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:paddingHorizontal="12dp"
                android:text="粗" />

            <!-- 橡皮擦 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEraser"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:paddingHorizontal="12dp"
                android:text="橡皮擦" />

            <!-- 復原 / 重做 / 清除 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUndo"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="12dp"
                android:text="↩" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRedo"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="12dp"
                android:text="↪" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearAll"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="12dp"
                android:text="清除" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 畫布 -->
    <com.rendy.classnote.ui.classrecord.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 底部按鈕 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="取消" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawSave"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="儲存" />

    </LinearLayout>
</LinearLayout>
