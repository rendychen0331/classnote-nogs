<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 日期 -->
        <TextView
            android:id="@+id/tvRecordDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:background="?attr/selectableItemBackground"
            android:drawablePadding="8dp"
            android:text="" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- 時間標籤 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTimeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/class_record_time_label"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_recent_history"
            app:endIconContentDescription="選擇時間">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTimeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 文字筆記（富文字編輯器） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/colorSurfaceContainer"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatBold"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="B"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatItalic"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="I"
                            android:textStyle="italic" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatUnderline"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="U" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatBullet"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="•" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatOrdered"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="1." />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatTable"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="⊞ 表格" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="?attr/colorOutline" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatUndo"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="↩" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFormatRedo"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="10dp"
                            android:text="↪" />

                    </LinearLayout>
                </HorizontalScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutline" />

                <WebView
                    android:id="@+id/webViewNote"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:scrollbars="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 手寫筆記縮圖 -->
        <HorizontalScrollView
            android:id="@+id/scrollDrawings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/layoutDrawings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp" />
        </HorizontalScrollView>

        <!-- 照片區 -->
        <HorizontalScrollView
            android:id="@+id/scrollPhotos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/layoutPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp" />
        </HorizontalScrollView>

        <!-- 錄音區 -->
        <LinearLayout
            android:id="@+id/layoutRecordings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <!-- AI 總結按鈕 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/class_record_ai_summary"
            android:visibility="gone" />

        <!-- AI 總結卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorPrimary"
            app:cardBackgroundColor="?attr/colorSurfaceContainer">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/class_record_ai_summary_label"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tvAiSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 儲存 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save" />

    </LinearLayout>

</ScrollView>
